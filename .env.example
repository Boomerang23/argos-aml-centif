# Backend (FastAPI) – copy to .env and adjust
# Database (default matches docker-compose db)
DATABASE_URL=postgresql+psycopg2://argos:argos@localhost:5432/argos_centif

# Auth
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
ACCESS_TOKEN_MINUTES=720

# Onboarding links (token signing; base URL = public URL where upload page is served)
ONBOARDING_LINK_SECRET=change-me-too-in-production
ONBOARDING_LINK_TTL_HOURS=72
# ONBOARDING_BASE_URL=https://api.example.com

# OpenSanctions (optional – leave unset to use mock)
# OPENSANCTIONS_API_KEY=
# OPENSANCTIONS_BASE_URL=https://api.opensanctions.org

# CORS (comma-separated allowed origins; default = http://localhost:3000,http://127.0.0.1:3000)
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# S3-compatible storage (optional – uploads go to local storage if unset)
# S3_ENDPOINT_URL=
# S3_REGION=us-east-1
# S3_BUCKET=argos-centif
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
